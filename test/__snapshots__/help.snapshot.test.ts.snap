exports[`--help snapshots > test create-batch 1`] = `
"Usage: testsprite test create-batch [options]

Create multiple FE tests from a JSONL of plan specs (FE-only)

Options:
  --plans <path>             JSONL file with one plan-from spec per line (≤ 50
                             specs, ≤ 5 MB)
  --plan-from-dir <dir>      directory of *.json plan files — each file is one
                             plan spec (≤ 50 files, ≤ 5 MB total). Sorted by
                             filename for determinism. Mutually exclusive with
                             --plans.
  --run                      after create, trigger each created test as a run
                             (default: false)
  --max-concurrency <n>      with --run, max in-flight triggers at once (1-100,
                             default: 50). The server caps run-triggers at
                             60/min/key; the CLI throttles to 50/min and
                             auto-retries RATE_LIMITED responses client-side —
                             raising this value does not bypass the server cap.
  --wait                     with --run, poll each run until terminal status
                             (default: false)
  --timeout <s>              with --run --wait, per-run max seconds to wait
                             (1-3600, default 600)
  --target-url <url>         with --run, override the project default env URL
                             for each run
  --idempotency-key <token>  opaque idempotency token for the batch create
                             (1-256 ASCII chars). Defaults to a UUIDv4 minted
                             per invocation; pin one yourself for safe retries.
  -h, --help                 display help for command

Global options (--dry-run, --output, --profile, --endpoint-url, --request-timeout, --verbose, --debug):
  testsprite --help
"
`;

