exports[`--help snapshots > project 1`] = `
"Usage: testsprite project [options] [command]

Manage TestSprite projects

Options:
  -h, --help                     display help for command

Commands:
  list [options]                 List projects visible to the API key
  
  Exit codes:
    0  success
    3  auth error
    5  validation error (e.g., bad --page-size)
   10  transport/network failure (UNAVAILABLE) — retry the command
  get <project-id>               Get a project by id
  create [options]               Create a new project
  update [options] <project-id>  Update project metadata
  help [command]                 display help for command
"
`;

